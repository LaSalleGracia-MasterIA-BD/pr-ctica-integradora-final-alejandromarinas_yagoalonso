# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
*.egg-info/
dist/
build/

# Data
# data/raw/ (synthetic fixtures for docker compose bootstrap) IS tracked so
# that the stack is fully reproducible and offline-capable.
data/processed/*
data/models/*
!data/processed/.gitkeep
!data/models/.gitkeep

# SQLite database files (live in the `pipeline-db` Docker named volume in
# production; locally the directory is the mount point). Keep the .gitkeep
# so the mount point exists, but never commit the actual .db / WAL sidecars.
data/db/*.db
data/db/*.db-wal
data/db/*.db-shm
data/db/*-journal
!data/db/.gitkeep

# Notebooks checkpoints
.ipynb_checkpoints/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Docker
*.log

# Environment
.env
.env.local

# Referencias locales (prompts auxiliares, drafts, notas de trabajo).
# Nunca llegan al repo. Ejemplo: guia de implementacion local generada
# durante la fase de diseño, que se guarda como contexto local para
# futuras iteraciones.
.local-refs/

# Artefactos de inspeccion del dashboard con Playwright MCP (logs +
# snapshots .yml) y screenshots tomados durante la revision de UI.
# Solo sirven en local mientras se inspecciona; no aportan valor en el repo.
.playwright-mcp/
dashboard-*.png

# Model weights (too large for git)
*.h5
*.pt
*.pth
*.onnx
*.pkl

# COVID-19 Radiography Database (Kaggle, ~1.5 GB). Se descarga manualmente
# via docs/runbooks/download-radiography-dataset.md. NUNCA se commitea al repo.
data/raw/covid_radiography/

# Modelo entrenado y meta del clasificador de radiografias.
# El bloque `data/models/*` arriba ignora todo en esa carpeta; aqui dejamos
# excepciones para artefactos que SI queremos commitear si caben (< 50 MB,
# RNF-4 de specs/clasificacion-radiografias.md).
!data/models/*.keras
!data/models/*.meta.json
